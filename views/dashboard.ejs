<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Dashboard - Pastefy</title>
    <style>
        body { background:#121212; color:#fff; font-family:Arial; padding:20px; }
        .container { max-width:900px; margin:auto; }
        textarea { width:100%; height:350px; background:#1e1e1e; color:#0f0; border:2px solid #444; padding:15px; font-family:monospace; }
        button { background:#ffcc00; color:#000; padding:12px 25px; font-size:16px; border:none; border-radius:6px; cursor:pointer; }
        li { background:#1a1a1a; padding:15px; margin:10px 0; border-radius:8px; }
    </style>
</head>
<body>
<div class="container">
    <h1>📘 Pastefy - Tus Loadstrings</h1>
    <a href="/logout" style="float:right;color:#ff6666;">Salir</a>

    <h2>Crear nuevo paste</h2>
    <form method="POST" action="/create">
        <textarea name="content" placeholder="Pega aquí tu script Lua..."></textarea><br>
        <button type="submit">Crear Paste</button>
    </form>

    <h2>Tus pastes (<%= pastes.length %>)</h2>
    <ul>
    <% pastes.forEach(p => { %>
        <li>
            <strong>ID:</strong> <%= p.id %><br>
            <strong>Creado:</strong> <%= p.created.toLocaleString() %><br><br>
            <a href="/paste/<%= p.id %>" style="color:#00ffaa;">Ver en navegador (como la foto)</a> | 
            <a href="/raw/<%= p.id %>" style="color:#ffcc00;" target="_blank">Raw para Delta</a><br>
            <button onclick="copyRaw('<%= p.id %>')">Copiar URL Raw</button>
        </li>
    <% }); %>
    </ul>
</div>

<script>
function copyRaw(id) {
    navigator.clipboard.writeText(location.origin + '/raw/' + id).then(() => alert('✅ URL Raw copiada!'));
}
</script>
</body>
</html>
