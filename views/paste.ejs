<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Loadstring</title>
    <style>
        body { background:#0d0d0d; color:#fff; font-family:system-ui; margin:0; height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center; }
        .header { display:flex; align-items:center; gap:15px; margin-bottom:30px; }
        .icon { font-size:48px; }
        h1 { color:#ffcc00; margin:0; }
        .code-box { background:#1a1a1a; border:1px solid #444; padding:25px; max-width:820px; width:90%; border-radius:12px; position:relative; box-shadow:0 0 30px rgba(0,0,0,0.8); }
        pre { color:#00ffaa; font-family:monospace; white-space:pre-wrap; overflow:auto; max-height:420px; margin:0; }
        .copy-btn { position:absolute; top:15px; right:15px; background:#333; color:#fff; border:none; padding:10px 20px; border-radius:6px; cursor:pointer; font-weight:bold; }
        .footer { margin-top:30px; color:#666; font-size:14px; }
    </style>
</head>
<body>
    <div class="header">
        <span class="icon">📘</span>
        <h1>Loadstring</h1>
    </div>

    <div class="code-box">
        <pre><code><%- paste.content %></code></pre>
        <button class="copy-btn" onclick="copyContent()">Copy</button>
    </div>

    <div class="footer">
        Contents can not be displayed on browser • <%= host %>
    </div>

<script>
function copyContent() {
    const text = document.querySelector('pre code').innerText;
    navigator.clipboard.writeText(text).then(() => alert('✅ Contenido copiado!'));
}
</script>
</body>
</html>
